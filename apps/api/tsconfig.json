{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@first-chair/shared": ["../../packages/shared/src/index.ts"],
      "@first-chair/shared/*": ["../../packages/shared/src/*.ts"]
    }
  },
  "include": ["src", "scripts", "test"],
  "references": [{ "path": "../../packages/shared" }]
}
