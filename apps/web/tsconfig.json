{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@first-chair/shared": ["../../packages/shared/src/index.ts"],
      "@first-chair/shared/*": ["../../packages/shared/src/*.ts"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "../../packages/shared" }]
}
